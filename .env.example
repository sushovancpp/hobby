# ─────────────────────────────────────────────
# MongoDB Atlas  (get this from Atlas → Connect → Drivers)
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/final-year

# ─────────────────────────────────────────────
# Admin / Developer password
# ─────────────────────────────────────────────
ADMIN_PASSWORD=DOTAI

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=final-year

# ─────────────────────────────────────────────
# Cloudinary (already in your account)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
